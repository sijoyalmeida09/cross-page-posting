<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.xml — tells the server "when someone hits /DisplayServlet, run DisplayServlet.java"

  So when the form in student.html posts to action="DisplayServlet", the container
  knows exactly which class to call. You can also do this with @WebServlet in the
  Java file; we have both here so the project works with or without annotations.
-->
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>Cross Page Posting Demo</display-name>
  <description>
    Form on student.html (Page A) posts to DisplayServlet (Page B).
    This descriptor wires the URL to the Java class that handles it.
  </description>

  <!-- If someone visits the app root, show the form first -->
  <welcome-file-list>
    <welcome-file>student.html</welcome-file>
  </welcome-file-list>

  <!-- Declare the servlet: "DisplayServlet" is implemented by class DisplayServlet -->
  <servlet>
    <servlet-name>DisplayServlet</servlet-name>
    <servlet-class>DisplayServlet</servlet-class>
  </servlet>

  <!-- Bind the path /DisplayServlet to that servlet -->
  <servlet-mapping>
    <servlet-name>DisplayServlet</servlet-name>
    <url-pattern>/DisplayServlet</url-pattern>
  </servlet-mapping>

</web-app>