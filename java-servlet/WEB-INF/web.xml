<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.xml — Deployment Descriptor
  
  Maps the URL pattern "/DisplayServlet" to the DisplayServlet class.
  When student.html submits to action="DisplayServlet", this file
  tells Tomcat which Java class handles that URL.
  
  Note: The @WebServlet("/DisplayServlet") annotation in the .java file
  does the same thing. Both are included here for academic completeness.
-->
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>Cross Page Posting Demo</display-name>
  <description>
    Demonstrates Cross Page Posting in Java Servlets.
    Form data submitted on student.html (Page A) is received
    and displayed by DisplayServlet.java (Page B).
  </description>

  <!-- Welcome file: first page loaded when app is accessed -->
  <welcome-file-list>
    <welcome-file>student.html</welcome-file>
  </welcome-file-list>

  <!-- Servlet Declaration -->
  <servlet>
    <servlet-name>DisplayServlet</servlet-name>
    <servlet-class>DisplayServlet</servlet-class>
  </servlet>

  <!-- Servlet Mapping: maps URL to the servlet above -->
  <servlet-mapping>
    <servlet-name>DisplayServlet</servlet-name>
    <url-pattern>/DisplayServlet</url-pattern>
  </servlet-mapping>

</web-app>